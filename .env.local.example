APP_ENV=development
APP_URL=http://localhost:3001
APP_PORT=3001

# MySQL (простые пароли для локалки)
DB_HOST=db
DB_PORT=3306
DB_NAME=arca_gateway_local
DB_USER=arca
DB_PASSWORD=local_password
DB_ROOT_PASSWORD=local_root_password

# Shopify — можно оставить пустым для UI-разработки
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_placeholder
SHOPIFY_WEBHOOK_SECRET=local_webhook_secret
SHOPIFY_API_VERSION=2024-01

# ArCa TEST endpoint — не нужны реальные данные банка
ARCA_USERNAME=your_test_username
ARCA_PASSWORD=your_test_password
ARCA_BASE_URL=https://ipaytest.arca.am:8445/payment/rest
ARCA_AUTH_MODE=1

# Курсы валют
DEFAULT_CURRENCY=AMD
DEFAULT_CURRENCY_CODE=051
SHOP_CURRENCY=EUR
EUR_RATE=430
USD_RATE=420

CANCEL_AFTER_MINUTES=30

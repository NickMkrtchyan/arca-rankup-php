APP_ENV=production
APP_URL=https://checkout.your-domain.com
APP_PORT=3001

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arca_gateway
DB_USER=arca
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_root_password

# Shopify Custom App
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here
SHOPIFY_API_VERSION=2024-01

# ArCa (ipay.arca.am) — provided by your bank
ARCA_USERNAME=your_arca_username
ARCA_PASSWORD=your_arca_password
ARCA_BASE_URL=https://ipay.arca.am/payment/rest
ARCA_AUTH_MODE=1

# Currency
DEFAULT_CURRENCY=AMD
DEFAULT_CURRENCY_CODE=051
SHOP_CURRENCY=EUR
EUR_RATE=430
USD_RATE=420

# Workers
CANCEL_AFTER_MINUTES=30
